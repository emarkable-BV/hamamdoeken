light_text_color":false,"heading_size":"h3","heading_color":""}},"1654050117f10d5d66-1":{"type":"text","settings":{"text":"<p>Wat begon als een webshop vanuit huis, is uitgegroeid tot een vertrouwd adres voor hamamdoeken, badjassen en bijpassende producten. Met nog steeds met dezelfde persoonlijke benadering als in het begin.<\/p>"}}},"block_order":["1654050117f10d5d66-0","1654050117f10d5d66-1"],"custom_css":[".rich-text__heading {width: 100%; max-width: 58rem; margin: 0 auto;}"],"settings":{"container":"container-narrow","color_schema":"background-1","text_alignment":"center","padding_top":100,"padding_bottom":0,"show_section_divider":false,"divider_width":"container","custom_id":"","custom_class":"","animations":"inherit"}},"8cada7c1-f0b3-48e7-8f44-9ac2bbdf7fe2":{"type":"collage-tabs","blocks":{"tab_ptbM8q":{"type":"tab","settings":{"content_color_schema":"background-2","navigation_title":"2010","image":"shopify:\/\/shop_images\/foto-van-mij-voor-op-over-hamamdoekencom-pagina.webp","heading":"2010","highlight_style":"none","enable_highlight_text_color":false,"heading_size":"h2","heading_color":"","subheading":"","description":"<p>Mijn naam is Grietje Zijlstra. In 2010 begon ik met Moments4Wellness.nl, een webshop gericht op ontspanning en cadeaus. Een jaar later ontdekte ik de hamamdoek. Een product dat niet alleen mooi is, maar vooral praktisch en veelzijdig.<\/p>","text_alignment":"center","button_label":"","button_link":"","button_style":"btn--primary","mobile_text_alignment":"inherit"}},"template--17157701599458__8cada7c1-f0b3-48e7-8f44-9ac2bbdf7fe2-tab-1":{"type":"tab","settings":{"content_color_schema":"accent","navigation_title":"2016","heading":"Our Journey","highlight_style":"none","enable_highlight_text_color":false,"heading_size":"h1","heading_color":"","subheading":"the first step","description":"<p>The story of our brand is one of passion, perseverance, and purpose. It all started with a desire to do better – to create activewear that not only looked good but also did good. Fueled by a love for fitness and a deep respect for the environment, our founder embarked on a journey to redefine the industry norms. Drawing inspiration from nature's colors and patterns, they set out to design workout wear that was not only stylish and functional but also eco-friendly.<\/p>","text_alignment":"left","button_label":"","button_link":"#","button_style":"btn--primary","mobile_text_alignment":"inherit"}},"bf0e39bb-afe7-4aed-96d7-0a79da248101":{"type":"tab","settings":{"content_color_schema":"accent","navigation_title":"2019","heading":"Establishing","highlight_style":"none","enable_highlight_text_color":false,"heading_size":"h1","heading_color":"","subheading":"made significant","description":"<p>Flairy made significant strides in establishing itself as a prominent player in the fashion industry. We expanded our product line to include a diverse range of clothing and accessories, each crafted with meticulous attention to detail and quality. Through innovative designs and customer-centric approaches, we garnered a loyal following and began to carve our niche in the competitive market.<\/p>","text_alignment":"left","button_label":"","button_link":"#","button_style":"btn--primary","mobile_text_alignment":"inherit"}},"ecdcc2e7-dc1a-4dc9-9f6d-519779df0e51":{"type":"tab","settings":{"content_color_schema":"accent","navigation_title":"2023","heading":"Our Successes","highlight_style":"none","enable_highlight_text_color":false,"heading_size":"h1","heading_color":"","subheading":"Building upon","description":"<p>We focused on sustainability and ethical practices, striving to minimize our environmental footprint while maintaining our commitment to delivering exceptional products. Collaborations with renowned designers and influencers further elevated our brand presence, allowing us to reach new audiences and expand our global reach. As we continue to evolve and adapt to the ever-changing landscape of fashion, Flairy remains dedicated to inspiring confidence.<\/p>","text_alignment":"left","button_label":"","button_link":"#","button_style":"btn--primary","mobile_text_alignment":"inherit"}},"tab_EHzajz":{"type":"tab","settings":{"content_color_schema":"background-2","navigation_title":"2026","heading":"Collage tabs heading","highlight_style":"none","enable_highlight_text_color":false,"heading_size":"h2","heading_color":"","subheading":"","description":"<p>Tell your brand's story through images<\/p>","text_alignment":"center","button_label":"Button label","button_link":"","button_style":"btn--primary","mobile_text_alignment":"inherit"}}},"block_order":["tab_ptbM8q","template--17157701599458__8cada7c1-f0b3-48e7-8f44-9ac2bbdf7fe2-tab-1","bf0e39bb-afe7-4aed-96d7-0a79da248101","ecdcc2e7-dc1a-4dc9-9f6d-519779df0e51","tab_EHzajz"],"custom_css":[".f-collage-tab--heading {--text-blocks-gap: 1.6rem;"],"settings":{"container":"container","color_schema":"","tab_heading_size":"h4","desktop_navigation_alignment":"center","desktop_image_position":"left","desktop_image_width":50,"image_aspect_ratio":"4\/3","padding_top":80,"padding_bottom":0,"show_section_divider":false,"divider_width":"container","custom_id":"","custom_class":"","animations":"inherit"}},"45e4c2ac-12b8-4ed1-a789-75b4dbc9c578":{"type":"multicolumn","blocks":{"template--17157701599458__45e4c2ac-12b8-4ed1-a789-75b4dbc9c578-column-1":{"type":"column","settings":{"show_image":true,"image":"shopify:\/\/shop_images\/favicon.svg","image_link":"","title":"Persoonlijk & vertrouwd ontstaan","heading_size":"h4","text":"<p>Wat ooit klein begon, vanuit huis in 2010, is uitgegroeid tot een webshop waar persoonlijk contact en betrokkenheid nog steeds centraal staan.<\/p>","text_size":"medium","button_text":"","button_link":"","button_style":"btn--underline"}},"23738779-93a8-4a1b-aa4a-382808fc8419":{"type":"column","settings":{"show_image":true,"image":"shopify:\/\/shop_images\/favicon.svg","image_link":"","title":"Productkennis en advies op maat","heading_size":"h4",