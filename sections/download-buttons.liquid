{%- comment -%}
  CUSTOM (Hamamdoeken): rij download-knoppen. Elk block = label + bestand-URL (PDF).
  Upload de PDF onder Content → Bestanden en plak de link in het url-veld van het block.
{%- endcomment -%}
{{ 'download-buttons.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign section_id = section.settings.custom_id | default: section.id
  assign custom_class = section.settings.custom_class

  assign animation_effect = settings.animations
  if animation_effect != 'none' and section.settings.animations != 'inherit'
    assign animation_effect = section.settings.animations
  endif
-%}
<div
  id="{{ section_id }}"
  class="f-downloads f-section-padding color-{{ section.settings.color_schema }}{% if custom_class != blank %} {{ custom_class }}{% endif %}"
  style="--section-padding-top: {{ section.settings.padding_top }}px; --section-padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="{{ section.settings.container }}">
    <div class="f-downloads__inner" style="--content-max-width: {{ section.settings.content_width }}px;">
      {%- if section.settings.heading != blank -%}
        <h2 class="f-downloads__heading {{ section.settings.heading_size }}">
          <motion-element class="block" data-motion="{{ animation_effect }}">{{ section.settings.heading | escape }}</motion-element>
        </h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="f-downloads__description rte">{{ section.settings.description }}</div>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <motion-element class="block f-downloads__list" data-motion="{{ animation_effect }}" data-motion-delay="50">
          {%- for block in section.blocks -%}
            {%- if block.settings.label != blank -%}
              <a
                class="btn {{ section.settings.button_style }} f-downloads__btn"
                {% if block.settings.file != blank %}href="{{ block.settings.file }}" download{% else %}aria-disabled="true"{% endif %}
                {{ block.shopify_attributes }}
              >
                <svg class="f-downloads__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                  <path d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <span>{{ block.settings.label | escape }}</span>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </motion-element>
      {%- endif -%}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Download-knoppen",
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Container breedte",
      "default": "container",
      "options": [
        { "value": "container", "label": "Vast" },
        { "value": "container-fluid", "label": "Uitgerekt" },
        { "value": "container-full", "label": "Volledige breedte" }
      ]
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Max. breedte",
      "min": 480,
      "max": 1100,
      "step": 20,
      "unit": "px",
      "default": 760
    },
    {
      "type": "color_scheme",
      "id": "color_schema",
      "label": "Kleurschema",
      "default": "background-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titel (optioneel)"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Titelgrootte",
      "default": "h3",
      "options": [
        { "value": "h4", "label": "H4" },
        { "value": "h3", "label": "H3" },
        { "value": "h2", "label": "H2" }
      ]
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Omschrijving (optioneel)"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Knopstijl",
      "default": "btn--primary",
      "options": [
        { "value": "btn--primary", "label": "Primair" },
        { "value": "btn--secondary", "label": "Secundair" },
        { "value": "btn--white", "label": "Wit" }
      ]
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding boven",
      "default": 8,
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding onder",
      "default": 64,
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Geavanceerd"
    },
    {
      "type": "text",
      "id": "custom_id",
      "label": "Custom ID"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom class"
    },
    {
      "type": "select",
      "id": "animations",
      "label": "Animatie",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Overnemen van thema" },
        { "value": "fade-in", "label": "Fade in" },
        { "value": "fade-in-up", "label": "Fade in omhoog" },
        { "value": "fade-in-left", "label": "Fade in links" },
        { "value": "fade-in-right", "label": "Fade in rechts" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "download",
      "name": "Download",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Download"
        },
        {
          "type": "url",
          "id": "file",
          "label": "Bestand / link",
          "info": "Upload de PDF onder Content → Bestanden en plak hier de link."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Download-knoppen",
      "blocks": [
        { "type": "download" },
        { "type": "download" },
        { "type": "download" }
      ]
    }
  ]
}
{% endschema %}
